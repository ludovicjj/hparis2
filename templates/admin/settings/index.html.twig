{% extends 'admin/admin_layout.html.twig' %}

{% block title %}Paramètres - {{ parent() }}{% endblock %}

{% block page_title %}Paramètres{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('admin_settings') }}
{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col lg:flex-row gap-6">
        <div class="lg:w-[300px] lg:shrink-0 flex flex-col">
            <div class="mb-6">
                <h2 class="text-lg font-semibold text-white">Logo du site</h2>
                <p class="text-slate-400 text-sm">Logo affiché dans la navigation du site public</p>
            </div>

            <div class="bg-slate-900 rounded-xl border border-slate-700 p-6 flex-1">
                {{ form_start(logoForm, {attr: {id: 'logo-form', class: 'h-full flex flex-col'}}) }}
                    <p class="text-slate-300 text-sm font-semibold mb-3">JPG, PNG · 1 Mo max · 600×600 px max</p>

                    <div class="relative inline-block bg-white rounded-lg border-2 border-slate-700 hover:border-purple-500 transition cursor-pointer">
                        <div id="logo-preview-zone" class="w-62 h-60 overflow-hidden flex items-center justify-center">
                            <img id="logo-preview-img"
                                 src="{{ logoUrl ?: '' }}"
                                 alt="Aperçu du logo"
                                 class="max-h-full max-w-full object-contain {{ logoUrl ? '' : 'hidden' }}">
                            <div id="logo-preview-placeholder"
                                 class="flex flex-col items-center gap-1 text-slate-400 {{ logoUrl ? 'hidden' : '' }}">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <span class="text-xs">Aucun logo</span>
                            </div>
                        </div>

                        {% if logoUrl %}
                            <button type="button"
                                    class="absolute bottom-2 right-2 bg-white hover:bg-red-50 border border-red-600 text-red-600 p-1.5 rounded-md transition cursor-pointer shadow-lg"
                                    data-media-delete
                                    data-url="{{ path('app_admin_settings_logo_delete') }}"
                                    data-token="{{ csrf_token('delete_logo') }}"
                                    data-confirm="Supprimer le logo ?"
                                    title="Supprimer le logo">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        {% endif %}
                    </div>

                    <p id="logo-file-name" class="text-slate-400 text-xs mt-3 truncate">Aucun fichier sélectionné</p>

                    {{ form_widget(logoForm.file, {attr: {class: 'hidden'}}) }}
                    {{ form_errors(logoForm.file, {attr: {class: 'text-red-400 text-xs mt-1'}}) }}

                    <div class="mt-auto pt-4 flex justify-center sm:justify-start">
                        <button type="submit"
                                class="bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded-lg shadow-lg hover:shadow-purple-500/25 transition-all text-sm">
                            {{ logoUrl ? 'Modifier le logo' : 'Enregister le logo' }}
                        </button>
                    </div>
                {{ form_end(logoForm) }}
            </div>
        </div>

        <div class="flex-1 min-w-0 flex flex-col">
            <div class="mb-6">
                <h2 class="text-lg font-semibold text-white">Hero du site</h2>
                <p class="text-slate-400 text-sm">Image principale affichée en haut du site public</p>
            </div>

            <div class="bg-slate-900 rounded-xl border border-slate-700 p-6 flex-1">
                {{ form_start(heroForm, {attr: {id: 'hero-form', class: 'h-full flex flex-col'}}) }}
                    <p class="text-slate-300 text-sm font-semibold mb-3">JPG, PNG · 3 Mo max · 2400×1600 px max</p>

                    <div class="relative">
                        <div id="hero-preview-zone"
                             class="w-full aspect-[2/1] bg-white rounded-lg overflow-hidden flex items-center justify-center transition cursor-pointer border-2 border-slate-700 hover:border-purple-500">
                            <img id="hero-preview-img"
                                 src="{{ heroUrl ?: '' }}"
                                 alt="Aperçu du hero"
                                 class="w-full h-full object-cover {{ heroUrl ? '' : 'hidden' }}">
                            <div id="hero-preview-placeholder"
                                 class="flex flex-col items-center gap-1 text-slate-400 {{ heroUrl ? 'hidden' : '' }}">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <span class="text-xs">Aucun hero</span>
                            </div>
                        </div>

                        {% if heroUrl %}
                            <button type="button"
                                    class="absolute bottom-2 right-2 bg-white hover:bg-red-50 border border-red-600 text-red-600 p-1.5 rounded-md transition cursor-pointer shadow-lg"
                                    data-media-delete
                                    data-url="{{ path('app_admin_settings_hero_delete') }}"
                                    data-token="{{ csrf_token('delete_hero') }}"
                                    data-confirm="Supprimer le hero ?"
                                    title="Supprimer le hero">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        {% endif %}
                    </div>

                    <p id="hero-file-name" class="text-slate-400 text-xs mt-3 truncate">Aucun fichier sélectionné</p>

                    {{ form_widget(heroForm.file, {attr: {class: 'hidden'}}) }}
                    {{ form_errors(heroForm.file, {attr: {class: 'text-red-400 text-xs mt-1'}}) }}

                    <div class="mt-auto pt-4 flex justify-center sm:justify-start">
                        <button type="submit"
                                class="bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded-lg shadow-lg hover:shadow-purple-500/25 transition-all text-sm">
                            {{ heroUrl ? 'Modifier le hero' : 'Enregister le hero' }}
                        </button>
                    </div>
                {{ form_end(heroForm) }}
            </div>
        </div>
    </div>

    <div class="mb-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
        <div>
            <h2 class="text-lg font-semibold text-white">Réseaux sociaux</h2>
            <p class="text-slate-400 text-sm">Gérez les liens vers vos réseaux sociaux affichés sur le site</p>
        </div>
        <a href="{{ path('app_admin_settings_social_link_create') }}"
           class="bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded-lg shadow-lg hover:shadow-purple-500/25 transition-all text-sm">
            + Ajouter un réseau
        </a>
    </div>

    {% if socialLinks is empty %}
        <div class="bg-slate-900 rounded-xl p-12 border border-slate-700 text-center">
            <svg class="w-16 h-16 mx-auto text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
            <p class="text-slate-400 mb-4">Aucun réseau social configuré</p>
            <a href="{{ path('app_admin_settings_social_link_create') }}"
               class="text-purple-400 hover:text-purple-300 transition text-sm">
                Ajouter votre premier réseau social &rarr;
            </a>
        </div>
    {% else %}
        <div id="social-links-sortable" data-reorder-url="{{ path('app_admin_settings_social_link_reorder') }}" class="space-y-3">
            {% for link in socialLinks %}
                <div data-id="{{ link.id }}" class="bg-slate-900 rounded-xl border border-slate-700 p-4 hover:bg-slate-800/50 transition">
                    {# Container desktop #}
                    <div class="flex items-center gap-3">
                        {# Drag handle #}
                        <span class="drag-handle cursor-grab active:cursor-grabbing text-slate-500 hover:text-slate-300 shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
                            </svg>
                        </span>

                        {# Icon + Platform #}
                        <div class="flex items-center space-x-3 text-white shrink-0">
                            {{ include('partials/icons/' ~ link.platform ~ '.html.twig', {class: 'w-5 h-5'}, ignore_missing=true) }}
                            <span class="font-medium capitalize">{{ link.platform }}</span>
                        </div>

                        {# URL #}
                        <a href="{{ link.url }}" target="_blank" class="hidden sm:block text-purple-400 hover:text-purple-300 transition text-sm truncate min-w-0 flex-1">
                            {{ link.url }}
                        </a>

                        {# Status #}
                        <form method="post" action="{{ path('app_admin_settings_social_link_toggle', {id: link.id}) }}" class="hidden sm:block shrink-0">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ link.id) }}">
                            <button type="submit" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium transition cursor-pointer
                                {{ link.active ? 'bg-green-500/20 text-green-400 hover:bg-green-500/30' : 'bg-slate-500/20 text-slate-400 hover:bg-slate-500/30' }}">
                                {{ link.active ? 'Actif' : 'Inactif' }}
                            </button>
                        </form>

                        {# Actions #}
                        <div class="hidden sm:flex items-center space-x-2 shrink-0">
                            <a href="{{ path('app_admin_settings_social_link_edit', {id: link.id}) }}"
                               class="p-2 border border-slate-600 rounded-md text-slate-400 hover:text-white hover:border-slate-400 transition" title="Modifier">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ path('app_admin_settings_social_link_delete', {id: link.id}) }}" class="inline"
                                  onsubmit="return confirm('Supprimer ce réseau social ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ link.id) }}">
                                <button type="submit" class="p-2 border border-red-900/50 rounded-md text-red-400 hover:text-red-300 hover:border-red-700 transition" title="Supprimer">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    {# Container : mobile #}
                    <div class="sm:hidden mt-3 space-y-3">
                        <a href="{{ link.url }}" target="_blank" class="text-purple-400 hover:text-purple-300 transition text-sm truncate block">
                            {{ link.url }}
                        </a>
                        <div class="flex items-center justify-between">
                            <form method="post" action="{{ path('app_admin_settings_social_link_toggle', {id: link.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ link.id) }}">
                                <button type="submit" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium transition cursor-pointer
                                    {{ link.active ? 'bg-green-500/20 text-green-400 hover:bg-green-500/30' : 'bg-slate-500/20 text-slate-400 hover:bg-slate-500/30' }}">
                                    {{ link.active ? 'Actif' : 'Inactif' }}
                                </button>
                            </form>
                            <div class="flex items-center space-x-2">
                                <a href="{{ path('app_admin_settings_social_link_edit', {id: link.id}) }}"
                                   class="p-2 border border-slate-600 rounded-md text-slate-400 hover:text-white hover:border-slate-400 transition" title="Modifier">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <form method="post" action="{{ path('app_admin_settings_social_link_delete', {id: link.id}) }}" class="inline"
                                      onsubmit="return confirm('Supprimer ce réseau social ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ link.id) }}">
                                    <button type="submit" class="p-2 border border-red-900/50 rounded-md text-red-400 hover:text-red-300 hover:border-red-700 transition" title="Supprimer">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
