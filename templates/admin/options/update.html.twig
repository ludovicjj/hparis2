{% extends 'admin/admin_layout.html.twig' %}

{% block title %}Modifier {{ video.title ?: 'la vidéo' }} - {{ parent() }}{% endblock %}

{% block page_title %}Modifier la vidéo (Options){% endblock %}

{% block javascripts %}
    <script src="{{ asset('build/ckeditor/ckeditor.js') }}"></script>
    {{ parent() }}
    {{ encore_entry_script_tags('admin_options_form') }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('admin_options_form') }}
{% endblock %}

{% block content %}
    <div class="w-full">
        <div class="bg-slate-900 rounded-xl p-4 sm:p-6 border border-slate-700 mb-6">
            <h2 class="text-lg font-semibold text-white mb-4">Lien</h2>
            <div class="flex flex-col sm:flex-row gap-2">
                <div class="flex-1 px-3 py-2 sm:px-4 sm:py-3 bg-slate-800 border border-slate-600 rounded-lg text-white truncate" id="video-url">
                    {{ front_video_url }}
                </div>
                <div class="flex flex-wrap gap-2">
                    <button type="button"
                            id="copy-url-btn"
                            class="grow justify-center px-3 py-2 sm:px-4 sm:py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        <span id="copy-url-text">Copier</span>
                    </button>
                    {% if not video.visibility %}
                        <button type="button"
                                id="reset-token-btn"
                                data-url="{{ path('app_admin_options_token', {id: video.id}) }}"
                                class="grow justify-center px-3 py-2 sm:px-4 sm:py-3 bg-slate-700 hover:bg-slate-600 text-white rounded-lg transition flex items-center gap-2"
                                title="Régénérer le token (invalidera l'ancien lien)">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                            </svg>
                            <span id="reset-token-text">Régénérer</span>
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>

        {{ form_start(form) }}
        <div class="bg-slate-900 rounded-xl p-6 border border-slate-700 mb-6">
            <div class="mb-6">
                <a href="{{ path('app_admin_options_index') }}" class="text-purple-400 hover:text-purple-300 transition">
                    &larr; Retour à Options
                </a>
            </div>

            <div class="space-y-6">
                <div>
                    {{ form_label(form.url, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    {{ form_widget(form.url, {'attr': {'class': 'w-full px-4 py-3 bg-slate-800 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition'}}) }}
                    <p class="text-slate-500 text-xs mt-2">Lien YouTube, Vimeo ou Dailymotion. Provider actuel : <code class="text-slate-400 capitalize">{{ video.provider.label }}</code></p>
                    {{ form_errors(form.url, {'attr': {'class': 'text-red-400 text-xs mt-1'}}) }}
                </div>

                <div>
                    {{ form_label(form.title, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-3 bg-slate-800 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition'}}) }}
                    {{ form_errors(form.title, {'attr': {'class': 'text-red-400 text-xs mt-1'}}) }}
                </div>

                <div>
                    {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-3 bg-slate-800 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition resize-none'}}) }}
                    {{ form_errors(form.description, {'attr': {'class': 'text-red-400 text-xs mt-1'}}) }}
                </div>

                <div class="flex items-center gap-4">
                    <span class="text-sm font-medium text-slate-300">{{ form_label(form.visibility, 'Vidéo publique', {'label_attr': {'class': 'text-sm font-medium text-slate-300'}}) }}</span>
                    <label class="relative inline-flex items-center cursor-pointer">
                        {{ form_widget(form.visibility, {'attr': {'class': 'sr-only peer'}}) }}
                        <div class="w-11 h-6 bg-slate-600 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-purple-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-purple-600"></div>
                    </label>
                </div>
            </div>

            <div class="flex items-center justify-end pt-6">
                <button type="submit"
                        class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-lg transition">
                    Enregistrer
                </button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
