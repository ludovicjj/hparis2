{% extends 'admin/admin_layout.html.twig' %}

{% block title %}Team - {{ parent() }}{% endblock %}

{% block page_title %}Team{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('admin_team') }}
{% endblock %}

{% block content %}
    <div class="mb-6 flex justify-between items-center">
        <p class="text-slate-400">{{ videoCount }} team(s)</p>
        <a href="{{ path('app_admin_team_create') }}"
           class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg transition flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvelle un élément
        </a>
    </div>

    {% if videos is empty %}
        <div class="bg-slate-900 rounded-xl p-12 border border-slate-700 text-center">
            <svg class="w-16 h-16 mx-auto text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <p class="text-slate-400 mb-4">Aucun élément pour le moment</p>
            <a href="{{ path('app_admin_team_create') }}"
               class="inline-flex items-center text-purple-400 hover:text-purple-300 transition">
                Ajouter votre élément
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>
    {% else %}
        <div id="videos-sortable"
             data-reorder-url="{{ path('app_admin_team_reorder') }}"
             class="bg-slate-900 rounded-xl border border-slate-700 overflow-hidden divide-y divide-slate-700">
            {% for video in videos %}
                <div data-id="{{ video.id }}" class="p-4 hover:bg-slate-800/50 transition">
                    {# Desktop #}
                    <div class="hidden sm:flex items-center gap-4">
                        <span class="drag-handle cursor-grab active:cursor-grabbing text-slate-500 hover:text-slate-300 shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
                            </svg>
                        </span>

                        <div class="min-w-0 flex-1">
                            <div class="text-white font-medium truncate">
                                {{ video.title ?: '(sans titre)' }}
                            </div>
                            <a href="{{ video.url }}" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 transition text-xs truncate block">
                                {{ video.url }}
                            </a>
                        </div>

                        {% if not video.visibility %}
                            <svg class="w-4 h-4 text-purple-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-label="Privée">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                            </svg>
                        {% endif %}

                        <span class="shrink-0 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-700 text-slate-300 capitalize">
                            {{ video.provider.label }}
                        </span>

                        <form method="post" action="{{ path('app_admin_team_toggle', {id: video.id}) }}" class="shrink-0">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ video.id) }}">
                            <button type="submit" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium transition cursor-pointer
                                {{ video.active ? 'bg-green-500/20 text-green-400 hover:bg-green-500/30' : 'bg-slate-500/20 text-slate-400 hover:bg-slate-500/30' }}">
                                {{ video.active ? 'Actif' : 'Inactif' }}
                            </button>
                        </form>

                        <div class="flex items-center gap-2 shrink-0">
                            <a href="{{ path('app_admin_team_update', {id: video.id}) }}"
                               class="p-2 border border-slate-600 rounded-md text-slate-400 hover:text-white hover:border-slate-400 transition" title="Modifier">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ path('app_admin_team_delete', {id: video.id}) }}" class="inline"
                                  onsubmit="return confirm('Supprimer cette vidéo ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ video.id) }}">
                                <button type="submit" class="p-2 border border-red-900/50 rounded-md text-red-400 hover:text-red-300 hover:border-red-700 transition" title="Supprimer">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    {# Mobile #}
                    <div class="sm:hidden">
                        <div class="flex items-start gap-3 mb-3">
                            <span class="drag-handle cursor-grab active:cursor-grabbing text-slate-500 hover:text-slate-300 shrink-0 mt-0.5">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
                                </svg>
                            </span>
                            <div class="min-w-0 flex-1">
                                <div class="text-white font-medium truncate mb-1">
                                    {{ video.title ?: '(sans titre)' }}
                                </div>
                                <a href="{{ video.url }}" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 transition text-xs truncate block">
                                    {{ video.url }}
                                </a>
                            </div>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                {% if not video.visibility %}
                                    <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-label="Privée">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                    </svg>
                                {% endif %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-700 text-slate-300 capitalize">
                                    {{ video.provider.label }}
                                </span>
                                <form method="post" action="{{ path('app_admin_team_toggle', {id: video.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ video.id) }}">
                                    <button type="submit" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium transition cursor-pointer
                                        {{ video.active ? 'bg-green-500/20 text-green-400 hover:bg-green-500/30' : 'bg-slate-500/20 text-slate-400 hover:bg-slate-500/30' }}">
                                        {{ video.active ? 'Actif' : 'Inactif' }}
                                    </button>
                                </form>
                            </div>
                            <div class="flex items-center gap-2">
                                <a href="{{ path('app_admin_team_update', {id: video.id}) }}"
                                   class="p-2 border border-slate-600 rounded-md text-slate-400 hover:text-white hover:border-slate-400 transition" title="Modifier">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <form method="post" action="{{ path('app_admin_team_delete', {id: video.id}) }}" class="inline"
                                      onsubmit="return confirm('Supprimer cette vidéo ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ video.id) }}">
                                    <button type="submit" class="p-2 border border-red-900/50 rounded-md text-red-400 hover:text-red-300 hover:border-red-700 transition" title="Supprimer">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
