{% extends 'admin/base_admin.html.twig' %}

{% block title %}Configuration 2FA - {{ parent() }}{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900">
        <div class="w-full max-w-md px-4 sm:px-6 py-8">
            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 sm:p-8 border border-white/10">
                <div class="text-center mb-6">
                    <h1 class="text-3xl font-bold text-white mb-2">Activer la 2FA</h1>
                    <p class="text-gray-400 text-sm">Scannez ce QR code avec votre application d'authentification (Google Authenticator, Microsoft Authenticator, Authy, 1Password…).</p>
                </div>

                <div class="flex justify-center bg-white rounded-xl p-4 mb-4">
                    {{ qr_svg|raw }}
                </div>

                <div class="mb-6">
                    <p class="text-gray-400 text-xs text-center mb-2">Impossible de scanner ? Saisissez cette clé manuellement :</p>
                    <code class="block bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-purple-300 text-center text-sm font-mono break-all select-all">{{ secret }}</code>
                </div>

                {% if error %}
                    <div class="bg-red-500/20 border border-red-500/50 text-red-200 px-4 py-3 rounded-lg mb-4">
                        {{ error }}
                    </div>
                {% endif %}

                <form method="post" class="space-y-6">
                    <div>
                        <label for="_auth_code" class="block text-sm font-medium text-gray-300 mb-2">Code de vérification</label>
                        <input type="text"
                               name="_auth_code"
                               id="_auth_code"
                               inputmode="numeric"
                               pattern="[0-9]{6}"
                               maxlength="6"
                               autocomplete="one-time-code"
                               class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition tracking-widest text-center text-xl"
                               required
                               autofocus
                               placeholder="123456">
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrf_token_id) }}">

                    <button type="submit"
                            class="w-full bg-purple-600 hover:bg-purple-700 text-white font-semibold py-3 px-4 rounded-lg shadow-lg hover:shadow-purple-500/25 transition-all">
                        Activer la 2FA
                    </button>
                </form>

                <div class="mt-6 text-center">
                    <a href="{{ path('app_logout') }}" class="text-gray-400 hover:text-white text-sm transition">
                        &larr; Se déconnecter
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
