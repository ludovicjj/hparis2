{% extends 'admin/admin_layout.html.twig' %}

{% block title %}Modifier {{ page.slug }} - {{ parent() }}{% endblock %}

{% block page_title %}Modifier la page{% endblock %}

{% block content %}
    <div class="w-full">
        {{ form_start(form) }}
        <div class="bg-slate-900 rounded-xl p-6 border border-slate-700 mb-6">
            <div class="mb-6 pb-6 border-b border-slate-700">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between sm:gap-0">
                    <a href="{{ path('app_admin_page_index') }}" class="inline-block text-slate-400 hover:text-white text-sm transition">
                        &larr; Retour aux pages
                    </a>
                    <p class="text-slate-400 text-sm">Slug : <code class="text-slate-300">{{ page.slug }}</code></p>
                </div>
            </div>

            <div class="space-y-6">
                <div>
                    {{ form_label(form.metaTitleFr, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    {{ form_widget(form.metaTitleFr, {'attr': {'class': 'w-full px-4 py-3 bg-slate-800 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition'}}) }}
                    {{ form_errors(form.metaTitleFr) }}
                    <p class="text-slate-500 text-xs mt-2">Recommandé : 60 à 70 caractères.</p>
                </div>

                <div>
                    {{ form_label(form.metaTitleEn, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    {{ form_widget(form.metaTitleEn, {'attr': {'class': 'w-full px-4 py-3 bg-slate-800 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition'}}) }}
                    {{ form_errors(form.metaTitleEn) }}
                    <p class="text-slate-500 text-xs mt-2">Recommended: 60 to 70 characters.</p>
                </div>

                <div>
                    {{ form_label(form.metaDescriptionFr, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    {{ form_widget(form.metaDescriptionFr, {'attr': {'class': 'w-full px-4 py-3 bg-slate-800 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition'}}) }}
                    {{ form_errors(form.metaDescriptionFr) }}
                    <p class="text-slate-500 text-xs mt-2">Recommandé : 150 à 160 caractères.</p>
                </div>

                <div>
                    {{ form_label(form.metaDescriptionEn, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    {{ form_widget(form.metaDescriptionEn, {'attr': {'class': 'w-full px-4 py-3 bg-slate-800 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition'}}) }}
                    {{ form_errors(form.metaDescriptionEn) }}
                    <p class="text-slate-500 text-xs mt-2">Recommended: 150 to 160 characters.</p>
                </div>
            </div>

            <div class="flex items-center justify-end pt-6">
                <button type="submit"
                        class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-lg transition">
                    Enregistrer
                </button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
