{% extends 'front/base_front.html.twig' %}

{% block title %}{{ gallery.title }} — Galerie photo | Hollywood Paris{% endblock %}

{% block meta_description %}{{ gallery.description ?: gallery.title ~ ' — Galerie photo réalisée par Hollywood Paris, studio photo professionnel à Paris.' }}{% endblock %}

{% block meta_robots -%}
    {%- if gallery.visibility -%}
        index, follow
    {%- else -%}
        noindex, nofollow
    {%- endif -%}
{%- endblock %}

{% block canonical %}{{ app.request.schemeAndHttpHost ~ path('app_front_gallery_show', {id: gallery.id, slug: gallery.slug ?: 'gallery'}) }}{% endblock %}

{% block og_type %}article{% endblock %}

{% block og_image -%}
    {%- if gallery.thumbnail -%}
        <meta property="og:image" content="{{ s3_url(gallery.thumbnail.filename) }}">
        <meta name="twitter:image" content="{{ s3_url(gallery.thumbnail.filename) }}">
    {%- endif -%}
{%- endblock %}

{% block jsonld -%}
    {%- if gallery.visibility -%}
        {%- set imageUrls = [] -%}
        {%- for lightboxPath in pictureLightboxPaths -%}
            {%- set imageUrls = imageUrls|merge([s3_url(lightboxPath)]) -%}
        {%- endfor -%}
        {%- set gallerySchema = {
            '@context': 'https://schema.org',
            '@type': 'ImageGallery',
            'name': gallery.title,
            'url': app.request.schemeAndHttpHost ~ path('app_front_gallery_show', {id: gallery.id, slug: gallery.slug ?: 'gallery'})
        } -%}
        {%- if gallery.description -%}
            {%- set gallerySchema = gallerySchema|merge({'description': gallery.description}) -%}
        {%- endif -%}
        {%- if imageUrls is not empty -%}
            {%- set gallerySchema = gallerySchema|merge({'image': imageUrls}) -%}
        {%- endif -%}
        <script type="application/ld+json">{{ gallerySchema|json_encode|raw }}</script>
    {%- endif -%}
{%- endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('front_gallery_show') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('front_gallery_show') }}
{% endblock %}

{% block body %}
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Header -->
        <div class="mb-8">
            <a href="{{ path('app_front_gallery_index', backParams) }}" class="inline-flex items-center text-gray-600 hover:text-gray-900 transition mb-4">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Retour aux galeries
            </a>
            <h1 class="font-['Bodoni_Moda',serif] font-normal text-3xl md:text-4xl font-bold text-gray-900 mb-2">{{ gallery.title }}</h1>
            {% if gallery.description %}
                <p class="text-gray-600 text-base md:text-lg">{{ gallery.description }}</p>
            {% endif %}
        </div>

        <!-- Pictures Grid -->
        <div
            id="pictures-grid"
            class="grid grid-cols-3 gap-0.5"
            data-api-url="{{ path('app_front_gallery_pictures', {id: gallery.id}) }}"
            data-initial-offset="{{ pictures|length }}"
            data-has-more="{{ hasMore ? 'true' : 'false' }}"
        >
            {% for picture in pictures %}
                <a href="{{ s3_url(picture.lightboxPath) }}" class="glightbox aspect-square overflow-hidden bg-gray-100 block relative group">
                    <img
                        src="{{ s3_url(picture.thumbnailPath) }}"
                        alt="{{ picture.originalName }}"
                        class="w-full h-full object-cover cursor-pointer"
                        loading="lazy"
                    >
                    <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></div>
                </a>
            {% endfor %}
        </div>

        <!-- Loading indicator -->
        {% if hasMore %}
            <div id="loading-indicator" class="flex justify-center py-8">
                <div class="flex items-center space-x-2 text-gray-500">
                    <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Chargement...</span>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
