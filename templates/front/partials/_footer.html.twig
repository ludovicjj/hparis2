<footer class="border-t border-gray-200 py-4 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <!-- Coordonnées -->
            <div class="text-gray-500">
                <p class="font-semibold text-gray-900">Assistante</p>
                <p>
                    <a href="tel:+33695592937" class="hover:text-gray-900 transition">+33 6 95 59 29 37</a>
                </p>
            </div>

            <!-- Réseaux sociaux -->
            {% set links = social_links() %}
            {% if links is not empty %}
                <div class="flex items-center space-x-4">
                    {% for link in links %}
                        <a href="{{ link.url }}"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="hover:opacity-75 transition" aria-label="{{ link.platform }}"
                        >
                            {{ include('partials/icons/' ~ link.platform ~ '.html.twig', {class: 'w-6 h-6', colored: true}, ignore_missing=true) }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</footer>
