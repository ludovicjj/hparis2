{% extends 'front/base_front.html.twig' %}

{% block title %}Hollywood Paris — Studio photo professionnel à Paris{% endblock %}

{% block meta_description %}Hollywood Paris est un studio photo professionnel situé à Paris. Mariages, événements, mode, portraits corporate — découvrez nos galeries de photographies.{% endblock %}

{% block og_image -%}
    {%- set heroForOg = hero_url() -%}
    {%- if heroForOg -%}
        <meta property="og:image" content="{{ heroForOg }}">
        <meta name="twitter:image" content="{{ heroForOg }}">
    {%- endif -%}
{%- endblock %}

{% block jsonld -%}
    {%- set socialUrls = [] -%}
    {%- for link in social_links() -%}
        {%- set socialUrls = socialUrls|merge([link.url]) -%}
    {%- endfor -%}
    {%- set businessImage = hero_url() ?: logo_url() -%}
    {%- set business = {
        '@context': 'https://schema.org',
        '@type': 'PhotographBusiness',
        'name': 'Hollywood Paris',
        'description': "Studio photo professionnel basé à Paris. Mariages, événements, mode, portraits corporate. Prestations sur rendez-vous.",
        'url': app.request.schemeAndHttpHost ~ path('app_front_home'),
        'telephone': '+33695592937',
        'areaServed': [
            {'@type': 'City', 'name': 'Paris'},
            {'@type': 'AdministrativeArea', 'name': 'Île-de-France'}
        ]
    } -%}
    {%- if businessImage -%}
        {%- set business = business|merge({'image': businessImage}) -%}
    {%- endif -%}
    {%- if socialUrls is not empty -%}
        {%- set business = business|merge({'sameAs': socialUrls}) -%}
    {%- endif -%}
    <script type="application/ld+json">{{ business|json_encode|raw }}</script>
{%- endblock %}

{% block body %}
    {% set heroUrl = hero_url() %}
    <section class="relative h-[calc(100dvh-186px)] md:h-[calc(100dvh-146px)] flex flex-col bg-white overflow-hidden">
        {% if heroUrl %}
            <img src="{{ heroUrl }}" alt="" class="absolute inset-0 w-full h-full object-cover">
            <div class="absolute inset-0 bg-black/40"></div>
        {% endif %}

        <div class="relative z-10 flex-1 flex flex-col px-4 sm:px-6 lg:px-8">
            <div class="flex-1 flex flex-col items-center justify-center text-center">
                <h1 class="font-['Bodoni_Moda',serif] font-normal uppercase tracking-wider text-4xl md:text-6xl {{ heroUrl ? 'text-white' : 'text-gray-900' }}">
                    Hollywood Paris
                </h1>
                <p class="mt-6 text-sm md:text-lg max-w-[200px] md:max-w-2xl {{ heroUrl ? 'text-gray-100' : 'text-gray-600' }}">
                    Votre studio photo professionnel au coeur de Paris
                </p>
            </div>
            <div class="pb-10 flex justify-center">
                <a href="{{ path('app_front_gallery_index') }}"
                   class="border {{ heroUrl ? 'border-white/70 text-white hover:bg-white/10' : 'border-gray-400 text-gray-700 hover:bg-gray-50' }} font-semibold px-8 py-3 rounded-lg transition-all">
                    Voir les galleries
                </a>
            </div>
        </div>
    </section>
{% endblock %}
