<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% if gsc_token() %}<meta name="google-site-verification" content="{{ gsc_token() }}">{% endif %}
    <title>{% block title %}{% endblock %}</title>

    <meta name="description" content="{% block meta_description %}{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <link rel="canonical" href="{% block canonical %}{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}{% endblock %}">

    <meta property="og:site_name" content="{{ site_name() }}">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{{ block('title') }}">
    <meta property="og:description" content="{{ block('meta_description') }}">
    <meta property="og:url" content="{{ block('canonical') }}">
    <meta property="og:locale" content="{{ app.request.locale == 'en' ? 'en_US' : 'fr_FR' }}">
    {% block og_image %}{% endblock %}

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ block('title') }}">
    <meta name="twitter:description" content="{{ block('meta_description') }}">

    <link rel="icon" href="{{ favicon_url() ?: 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>' }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:wght@400;500;600;700&display=swap" rel="stylesheet">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app_common') }}
        {{ encore_entry_link_tags('front_app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app_common') }}
        {{ encore_entry_script_tags('front_app') }}
    {% endblock %}

    {% block jsonld %}{% endblock %}
</head>
<body>
    <div class="min-h-[100dvh] flex flex-col bg-white">
        {% include 'front/partials/_navbar.html.twig' %}

        <main class="flex-grow flex flex-col bg-white">
            {% block body %}{% endblock %}
        </main>

        {% include 'front/partials/_footer.html.twig' %}
    </div>
</body>
</html>
